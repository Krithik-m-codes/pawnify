// Pawnify - Gold/Silver Pawn Broker Management System
// Prisma Schema - PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum Role {
  ADMIN
  STAFF
}

enum MetalType {
  GOLD
  SILVER
}

enum LoanStatus {
  ACTIVE
  CLOSED
}

enum KycDocType {
  AADHAAR
  PAN
  VOTER_ID
  PASSPORT
  DRIVING_LICENSE
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CARD
}

enum ChargeType {
  PROCESSING_FEE
  PENAL_CHARGE
  OTHER
}

enum TransactionType {
  DISBURSEMENT
  PAYMENT
  CLOSURE
  ITEM_RELEASE
}

enum FollowUpStatus {
  PENDING
  DONE
  CANCELLED
}

// ==================== BETTER AUTH TABLES ====================
// These are required by Better Auth for session management.
// We extend the user model with our domain-specific fields.

model user {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Domain-specific fields
  role          Role      @default(STAFF)
  phone         String?
  isActive      Boolean   @default(true)
  passwordHash  String?

  // Relations
  sessions      session[]
  accounts      account[]

  customersCreated  Customer[] @relation("CreatedByStaff")
  loansHandled      Loan[]     @relation("HandledByStaff")
  paymentsCollected Payment[]  @relation("CollectedByStaff")
  followUpsAssigned FollowUp[] @relation("AssignedStaff")
  kycVerified       KycDocument[] @relation("VerifiedByStaff")
}

model session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

// ==================== DOMAIN MODELS ====================

model Customer {
  id           String        @id @default(cuid())
  fullName     String
  phone        String        @unique
  email        String?
  dob          DateTime?
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  pincode      String
  photoUrl     String?
  createdById  String
  createdBy    user          @relation("CreatedByStaff", fields: [createdById], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  kycDocuments KycDocument[]
  loans        Loan[]

  @@index([phone])
  @@index([fullName])
}

model KycDocument {
  id           String     @id @default(cuid())
  customerId   String
  customer     Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  docType      KycDocType
  docNumber    String
  fileUrl      String?
  status       KycStatus  @default(PENDING)
  verifiedById String?
  verifiedBy   user?      @relation("VerifiedByStaff", fields: [verifiedById], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([customerId, docType])
}

// ==================== LOANS ====================

model Loan {
  id                   String        @id @default(cuid())
  loanNumber           String        @unique
  customerId           String
  customer             Customer      @relation(fields: [customerId], references: [id])
  handledById          String
  handledBy            user          @relation("HandledByStaff", fields: [handledById], references: [id])

  loanDate             DateTime      @default(now())
  dueDate              DateTime
  tenureMonths         Int
  interestRateMonthly  Decimal       @db.Decimal(6, 3)
  ltvPercent           Decimal       @db.Decimal(5, 2)
  gracePeriodDays      Int           @default(7)

  totalAssessedValue   Decimal       @db.Decimal(12, 2)
  principalAmount      Decimal       @db.Decimal(12, 2)
  principalOutstanding Decimal       @db.Decimal(12, 2)
  lastSettledDate      DateTime      @default(now())

  status               LoanStatus    @default(ACTIVE)
  closedAt             DateTime?
  closedById           String?
  notes                String?

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  items                LoanItem[]
  payments             Payment[]
  charges              LoanCharge[]
  transactions         LedgerEntry[]
  followUps            FollowUp[]

  @@index([status])
  @@index([dueDate])
  @@index([customerId])
}

model LoanItem {
  id                   String     @id @default(cuid())
  loanId               String
  loan                 Loan       @relation(fields: [loanId], references: [id], onDelete: Cascade)

  metalType            MetalType
  description          String
  purityLabel          String
  purityPercent        Decimal    @db.Decimal(5, 2)
  grossWeightGrams     Decimal    @db.Decimal(8, 3)
  stoneWeightGrams     Decimal    @db.Decimal(8, 3) @default(0)
  netWeightGrams       Decimal    @db.Decimal(8, 3)
  fineWeightGrams      Decimal    @db.Decimal(8, 3)
  valuationRatePerGram Decimal    @db.Decimal(10, 2)
  assessedValue        Decimal    @db.Decimal(12, 2)

  packetNumber         String     @unique
  storageLocation      String
  photoUrl             String?
  releasedAt           DateTime?

  createdAt            DateTime   @default(now())
}

model LoanCharge {
  id         String     @id @default(cuid())
  loanId     String
  loan       Loan       @relation(fields: [loanId], references: [id], onDelete: Cascade)
  chargeType ChargeType
  amount     Decimal    @db.Decimal(12, 2)
  isSettled  Boolean    @default(false)
  createdAt  DateTime   @default(now())
}

model Payment {
  id                 String      @id @default(cuid())
  loanId             String
  loan               Loan        @relation(fields: [loanId], references: [id])
  receiptNumber      String      @unique
  paymentDate        DateTime    @default(now())
  amountPaid         Decimal     @db.Decimal(12, 2)
  mode               PaymentMode
  allocatedCharges   Decimal     @db.Decimal(12, 2) @default(0)
  allocatedInterest  Decimal     @db.Decimal(12, 2) @default(0)
  allocatedPrincipal Decimal     @db.Decimal(12, 2) @default(0)
  collectedById      String
  collectedBy        user        @relation("CollectedByStaff", fields: [collectedById], references: [id])
  notes              String?
  createdAt          DateTime    @default(now())
}

model LedgerEntry {
  id             String          @id @default(cuid())
  loanId         String
  loan           Loan            @relation(fields: [loanId], references: [id])
  type           TransactionType
  amount         Decimal         @db.Decimal(12, 2)
  principalAfter Decimal         @db.Decimal(12, 2)
  referenceId    String?
  description    String
  createdAt      DateTime        @default(now())

  @@index([loanId, createdAt])
}

model FollowUp {
  id           String         @id @default(cuid())
  loanId       String
  loan         Loan           @relation(fields: [loanId], references: [id])
  note         String
  dueDate      DateTime
  status       FollowUpStatus @default(PENDING)
  assignedToId String?
  assignedTo   user?          @relation("AssignedStaff", fields: [assignedToId], references: [id])
  createdAt    DateTime       @default(now())
}

model AppSetting {
  key   String @id
  value String
}
