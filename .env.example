# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/pawnify"

# Better Auth
BETTER_AUTH_SECRET="your-secret-key-change-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# App
NODE_ENV="development"

# Set to "true" to log interest/payment/auth decisions to the console (see src/lib/debug.ts)
DEBUG="false"

# Required in production to authorize the /api/cron/update-rates endpoint (Vercel sends
# this as `Authorization: Bearer <value>` for scheduled cron requests). Optional locally.
CRON_SECRET=""
