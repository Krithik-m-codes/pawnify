# Config for the root docker-compose.yml self-hosted stack.
# Copy this file to `.env` (same directory as docker-compose.yml) and fill in
# real values, then run: docker compose up --build
#
# This file is only consumed by docker-compose. backend/ and web/ each have
# their own .env.example for running outside Docker (npm run dev).

# ── Postgres (run locally by this compose stack) ──
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=pawnify

# ── Supabase — an external project, not started by this file. Create one at
#    supabase.com (or point at a separately self-hosted Supabase stack). Used
#    for auth-adjacent storage and object storage; Postgres above is the
#    app's own relational database (Prisma + Row-Level Security). ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Secrets — generate long random strings, e.g. `openssl rand -hex 32` ──
JWT_SECRET=change-me
CRON_SECRET=change-me
BETTER_AUTH_SECRET=change-me

# ── Dodo Payments (billing) — https://docs.dodopayments.com. Optional: only
#    needed if Cloud SaaS billing/webhooks are in use. ──
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode

# ── Public URLs — must be reachable from END USERS' BROWSERS, not just from
#    other containers. localhost is only correct if you access this machine
#    directly; override all of these to your real domain/IP otherwise. ──
APP_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_DEMO_MODE=false
