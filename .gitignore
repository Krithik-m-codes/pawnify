# ==========================================
# Pawnify Monorepo Root .gitignore
# ==========================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build & Next.js Output
dist/
build/
out/
.next/
*.tsbuildinfo

# Environment & Secrets (Never commit real credentials)
.env
.env.*
!.env.example

# Logs & Debugging
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test & Coverage Reports
coverage/
.nyc_output/
junit.xml

# Editor & OS Cruft
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# AI Assistant Caches (Local user sessions)
.claude/
.gemini/
